# ========================================================================
# Axel Messenger — конфигурация окружения
# ========================================================================
# Скопируй этот файл в .env (для локалки) или впиши переменные в
# Render Dashboard → Environment.
# ========================================================================

# --- Базовое ---
NODE_ENV=production
PORT=3000
APP_URL=https://axel-messenger.onrender.com   # ВАЖНО: URL твоего деплоя
# Дополнительные разрешённые origin'ы через запятую (preview-деплои, кастомные домены).
# APP_URLS=https://axel-pr-12.onrender.com,https://chat.example.com

# --- JWT (обязательно в production!) ---
# Сгенерируй случайной командой: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА

# --- База данных: Neon ---
# Получи строку подключения в Neon Console → Dashboard → Connection Details
# Уже содержит ?sslmode=require — не убирай!
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Строгая проверка TLS-сертификата БД (защита от MITM). По умолчанию TRUE —
# у Neon/Supabase/RDS валидные публичные сертификаты, проверка работает
# из коробки. Отключайте (DB_SSL_STRICT=false) только если провайдер использует
# свой CA и вы временно не можете его поставить.
# Если у провайдера свой CA — положите его в DB_SSL_CA в виде PEM-строки
# (переносы строк можно экранировать как \n).
DB_SSL_STRICT=true
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# --- Хранилище файлов: Backblaze B2 ---
# Рекомендуемый режим для B2: native API (STORAGE_MODE=b2).
# S3-режим можно использовать только если твой B2 стабильно совместим с AWS SDK.
STORAGE_MODE=b2
S3_BUCKET=axel-messenger-uploads          # имя твоего бакета в B2
S3_REGION=us-west-002                     # можно оставить для совместимости
S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
S3_ACCESS_KEY_ID=твой_keyID_из_B2
S3_SECRET_ACCESS_KEY=твой_applicationKey_из_B2

# --- Telegram бот (для отправки кодов входа вместо SMS) ---
TELEGRAM_BOT_TOKEN=                       # получи у @BotFather
TELEGRAM_BOT_USERNAME=                    # без @, например: AxelMessengerBot
# Секрет, которым подписывается каждый POST /telegram/webhook (защита от спуфинга).
# Если оставить пустым — будет детерминированно сгенерирован из JWT_SECRET.
# Допустимые символы: A-Z, a-z, 0-9, _ и -, длина 1..256.
# TELEGRAM_WEBHOOK_SECRET=

# --- Web Push (VAPID) — браузерные push-уведомления ---
# Если оставить пустыми — push отключается, приложение работает как раньше
# (in-app уведомления через Notification API, пока вкладка открыта).
# Чтобы включить, сгенерируй пару ключей ОДИН раз и положи в Render:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Скопируй publicKey и privateKey в переменные ниже. ПРИВАТНЫЙ КЛЮЧ — секрет!
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Subject — обязателен по RFC 8292. mailto: или https://-URL. Push-сервисы
# браузеров используют это, чтобы связаться с тобой при проблемах. Если не
# задать — будет mailto:admin@<твой APP_URL hostname>.
# VAPID_SUBJECT=mailto:you@example.com

# --- Прочее ---
SUPPORT_PHONE=                            # номер первого суперадмина (опц.)
ALLOW_DEV_CODE_RESPONSE=false             # НИКОГДА не ставь true в production
