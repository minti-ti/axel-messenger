# ========================================================================
# Axel Messenger — конфигурация окружения
# ========================================================================
# Скопируй этот файл в .env (для локалки) или впиши переменные в
# Render Dashboard → Environment.
# ========================================================================

# --- Базовое ---
NODE_ENV=production
PORT=3000
APP_URL=https://axel-messenger.onrender.com   # ВАЖНО: URL твоего деплоя

# --- JWT (обязательно в production!) ---
# Сгенерируй случайной командой: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА

# --- База данных: Neon ---
# Получи строку подключения в Neon Console → Dashboard → Connection Details
# Уже содержит ?sslmode=require — не убирай!
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# --- Хранилище файлов: Backblaze B2 ---
# Рекомендуемый режим для B2: native API (STORAGE_MODE=b2).
# S3-режим можно использовать только если твой B2 стабильно совместим с AWS SDK.
STORAGE_MODE=b2
S3_BUCKET=axel-messenger-uploads          # имя твоего бакета в B2
S3_REGION=us-west-002                     # можно оставить для совместимости
S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
S3_ACCESS_KEY_ID=твой_keyID_из_B2
S3_SECRET_ACCESS_KEY=твой_applicationKey_из_B2

# --- Telegram бот (для отправки кодов входа вместо SMS) ---
TELEGRAM_BOT_TOKEN=                       # получи у @BotFather
TELEGRAM_BOT_USERNAME=                    # без @, например: AxelMessengerBot

# --- Прочее ---
SUPPORT_PHONE=                            # номер первого суперадмина (опц.)
ALLOW_DEV_CODE_RESPONSE=false             # НИКОГДА не ставь true в production
