# === ОСНОВНЫЕ НАСТРОЙКИ ===
NODE_ENV=production
PORT=3000
APP_URL=https://yourdomain.onrender.com

# JWT секрет для токенов (генерируйте новый для production)
JWT_SECRET=your_super_secret_jwt_key_here_generate_a_strong_random_string

# === БАЗА ДАННЫХ ===
# Если используется PostgreSQL на Render:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Или отдельные параметры:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messenger
DB_USER=messenger
DB_PASSWORD=your_db_password

# === ХРАНИЛИЩЕ ФАЙЛОВ ===
# Локальное хранилище (для разработки):
STORAGE_MODE=local

# S3-совместимое хранилище (для production на Render)
# STORAGE_MODE=s3
# S3_BUCKET=my-bucket-name
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key

# Backblaze B2 пример:
# STORAGE_MODE=s3
# S3_BUCKET=my-files
# S3_REGION=us-west-001
# S3_ENDPOINT=https://s3.us-west-001.backblazeb2.com
# S3_ACCESS_KEY_ID=appKeyId
# S3_SECRET_ACCESS_KEY=appKey

# DigitalOcean Spaces пример:
# STORAGE_MODE=s3
# S3_BUCKET=my-space
# S3_REGION=nyc3
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_ACCESS_KEY_ID=spaces_key
# S3_SECRET_ACCESS_KEY=spaces_secret

# === TWILIO (SMS) ===
# Если нужна двухфакторная аутентификация через SMS
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM=+1234567890

# === TELEGRAM БОТ ===
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_BOT_USERNAME=MyAwesomeBot

# === ОПЦИИ РАЗРАБОТКИ ===
# Позволяет использовать код '000000' для входа (только для разработки!)
ALLOW_DEV_CODE_RESPONSE=false

# === ПОДДЕРЖКА ===
SUPPORT_PHONE=+1234567890
