--- a/.env.example
+++ b/.env.example
@@ -19,6 +19,12 @@ JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_
 # Уже содержит ?sslmode=require — не убирай!
 DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
 
+# Строгая проверка TLS-сертификата БД (защита от MITM). По умолчанию false,
+# т.к. у managed-Postgres узлы ротируются. Если включаешь — желательно положить
+# CA провайдера в DB_SSL_CA (PEM-строкой).
+DB_SSL_STRICT=false
+# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
+
 # --- Хранилище файлов: Backblaze B2 ---
 # Рекомендуемый режим для B2: native API (STORAGE_MODE=b2).
 # S3-режим можно использовать только если твой B2 стабильно совместим с AWS SDK.
diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
new file mode 100644
index 0000000..1fb7de5
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,34 @@
+name: CI
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+    branches: [main]
+
+jobs:
+  build:
+    runs-on: ubuntu-latest
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: 20
+          cache: npm
+
+      - name: Install dependencies
+        run: npm ci
+
+      # Проверяем, что все серверные файлы хотя бы синтаксически валидны.
+      - name: Syntax check (node --check)
+        run: |
+          find src -name '*.js' -print0 | xargs -0 -n1 node --check
+
+      # Аудит зависимостей. Падаем только на high/critical, чтобы шум moderate
+      # из транзитивных пакетов не блокировал пайплайн.
+      - name: npm audit (high+critical)
+        run: npm audit --audit-level=high
